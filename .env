# ============================================================
#  MISE — Backend Environment Variables
#  Copy to .env and fill in your values
# ============================================================

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:svXtfLskvErpZdHuXjAcmTUHUZTGDOWq@shortline.proxy.rlwy.net:13969/railway"


# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-base64-64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL="redis://default:pzpvMxPQXBPOoUcixiNDxHDVeYVbrwSv@shortline.proxy.rlwy.net:16701"

# CORS (comma-separated frontend URLs)
CORS_ORIGIN=http://localhost:5173

# ── Payment Gateway (pick one) ────────────────────────────────
PAYMENT_GATEWAY_PROVIDER=mock   # stripe | iyzico | paytr | mock

STRIPE_SECRET_KEY=sk_test_...
IYZICO_API_KEY=sandbox-...
IYZICO_SECRET_KEY=sandbox-...
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# ── Delivery Platforms ────────────────────────────────────────
DEFAULT_BRANCH_ID=branch-main
YEMEKSEPETI_API_KEY=
YEMEKSEPETI_WEBHOOK_SECRET=
GETIR_API_KEY=
GETIR_WEBHOOK_SECRET=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_SUPPLIER_ID=

# ── SMS (pick one) ────────────────────────────────────────────
SMS_PROVIDER=mock   # twilio | netgsm | mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
NETGSM_USER_CODE=
NETGSM_PASSWORD=
NETGSM_HEADER=MISEPOS

# ── Email (pick one) ──────────────────────────────────────────
EMAIL_PROVIDER=mock   # smtp | sendgrid | mock
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=
SENDGRID_FROM=

# ── S3 / Object Storage ───────────────────────────────────────
S3_BUCKET=mise-pos
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── API Base URL (for payment gateway callbacks) ───────────────
API_BASE_URL=http://localhost:3001

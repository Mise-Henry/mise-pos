{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "commonjs",
    "lib":                        ["ES2022"],
    "outDir":                     "./dist",
    "rootDir":                    "./src",
    "strict":                     false,
    "esModuleInterop":            true,
    "skipLibCheck":               true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":          true,
    "declaration":                true,
    "sourceMap":                  true,
    "noUnusedLocals":             false,
    "exactOptionalPropertyTypes": false,
    "noUnusedParameters":         false
  },
 "include": ["src/**/*"],
 "exclude": ["node_modules", "dist"]
}
